for f in *.fastq; do
    # 1. Strip the .fastq extension to get the SRR ID
    name="${f%.fastq}"
    
    echo "Generating unaligned BAM for: $f"

    # 2. Convert to BAM in one step using a pipe (|)
    # minimap2 sends the data to samtools, which writes it to the final .bam file
    minimap2 -a /dev/null "$f" | samtools view -bS - > "${name}.bam"

    echo "Finished: ${name}.bam"
    echo "---"
done
'''
