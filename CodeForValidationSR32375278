###The shell script:
``` 
for f in *.fastq; do
    # 1. Create a clean name for the output (e.g., sample1.fastq -> sample1_summary.txt)
    base_name="${f%.fastq}"
    output_file="${base_name}_summary.txt"

    echo "Generating report for $f..."

    # 2. Start writing the text file
    echo "========================================" > "$output_file"
    echo "QC REPORT FOR: $f" >> "$output_file"
    echo "DATE: $(date)" >> "$output_file"
    echo "========================================" >> "$output_file"

    # 3. Calculate Integrity
    lines=$(wc -l < "$f")
    if [ $((lines % 4)) -eq 0 ]; then
        echo "Integrity:       PASS (Line count is valid)" >> "$output_file"
    else
        echo "Integrity:       FAIL (File may be truncated)" >> "$output_file"
    fi

    # 4. Calculate Read Count and Bases
    reads=$((lines / 4))
    bases=$(awk 'NR%4==2{sum+=length($0)} END{print sum}' "$f")
    
    # Calculate Average Length (only if reads > 0 to avoid error)
    if [ $reads -gt 0 ]; then
        avg_len=$((bases / reads))
    else
        avg_len=0
    fi

    echo "Total Reads:     $reads" >> "$output_file"
    echo "Total Bases:     $bases" >> "$output_file"
    echo "Average Length:  $avg_len bp" >> "$output_file"

    # 5. Check for PacBio Adapters (SMRTbell)
    adapter_count=$(grep -c "ATCTCTCTCAACAACAACAACGGAGGAGGAGGAGAGAGAT" "$f")
    echo "Adapter Hits:    $adapter_count" >> "$output_file"
    
    echo "----------------------------------------" >> "$output_file"
    echo "Report saved to: $output_file"

    echo "Filename,Reads,Bases,AvgLength,Adapters" > summary_table.csv
done

for f in *_summary.txt; do
    # Get the specific values using grep and awk
    name=$(grep "QC REPORT FOR" "$f" | awk '{print $NF}')
    reads=$(grep "Total Reads" "$f" | awk '{print $NF}')
    bases=$(grep "Total Bases" "$f" | awk '{print $NF}')
    avg=$(grep "Average Length" "$f" | awk '{print $3}')
    adapters=$(grep "Adapter Hits" "$f" | awk '{print $NF}')
    
    # Append to the CSV
    echo "$name,$reads,$bases,$avg,$adapters" >> summary_table.csv
done


