# Execute this file with your VM or local machine's cpus.  As per Linux: lscpu and adjust
conda.enabled = true
conda.cacheDir = "${baseDir}/conda"

executor {
    name = 'local'
    // Let Nextflow use the entire machine.
    cpus = 36 // <-- This now matches your hardware.
    memory = '256GB'
}

singularity {
    enabled = true
    autoMounts = true
}
process {
    // Default resources
    cpus = 4
    memory = '8GB'
    time = '6h'

    withLabel: 'process_low' {
        cpus = 2
        memory = '4GB'
        time = '1h'
    }

    withLabel: 'process_medium' {
        // This is still a good size, allows for 4 parallel jobs (4 * 8 = 32 CPUs)
        cpus = 8
        memory = '32GB'
        time = '8h'
    }

    withLabel: 'process_high' {
        // --- THIS IS THE CRITICAL OPTIMIZATION ---
        // By setting this to 12, you can now run THREE of these jobs at the same time (3 * 12 = 36 CPUs).
        cpus = 12
        // Adjust memory accordingly. If one job needed ~192GB, it was likely inefficient.
        // Let's start with a more reasonable 80GB per job.
        memory = '80GB'
        time = '48h'
    }
}

params {
    // --- INPUTS ---
    input_bam = "inputs/*.bam"
    bakta_db = "/home/dnanexus/databases/bakta_db/db"

    // --- NEW: Centralized URL for the reference genome ---
    // Now you only need to change the wget link in this one spot.
    bacterial_ref_url = "https://ftp.ncbi.nlm.nih.gov/genomes/all/GCF/000/019/595/GCF_000019595.2_ASM1959v2/GCF_000019595.2_ASM1959v2_genomic.fna.gz"
    
    // --- OUTPUTS ---
    outdir = "./results"

    // --- RASUSA PARAMS (NOW INTERACTIVE) ---
    // By setting these to 'false', Nextflow will prompt the user for them if they
    // are not provided on the command line (e.g., --genome_size '5.2m')
    genome_size = false
    coverage = false
}

